---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
const {
  title = 'hjadmz',
  description = 'hjadmz — static-first design engineering and systems architecture.',
  robots = 'index,follow',
} = Astro.props;
const canonicalUrl = Astro.url.href;
const isPostPath = /^\/log\/[^/]+\/?$/.test(Astro.url.pathname);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#F9FAFB" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#020617" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        if (stored === 'light' || stored === 'dark') {
          document.documentElement.dataset.theme = stored;
          return;
        }
        document.documentElement.dataset.theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      })();
    </script>
    <title>{title}</title>
  </head>
  <body data-is-post={isPostPath ? 'true' : 'false'}>
    <div class="noise-overlay" aria-hidden="true"></div>
    <a href="#main" class="skip-link">Skip to content</a>
    <div class="min-h-screen grid grid-rows-[auto_1fr_auto] px-6 md:px-16 lg:px-24">
      <Header />
      <main id="main" class="reading-column w-full py-16 page-enter">
        <slot />
      </main>
      <Footer />
    </div>
    <script is:inline>
      (() => {
        if (document.body.dataset.isPost !== 'true') {
          document.body.classList.remove('focus-mode');
          return;
        }

        let lastScrollY = window.scrollY;
        let ticking = false;
        const BOTTOM_THRESHOLD_PX = 50;
        const SCROLL_DOWN_START_PX = 100;
        const SCROLL_UP_THRESHOLD_PX = 10;
        const TOP_THRESHOLD_PX = 50;

        const updateFocusMode = () => {
          const currentScrollY = window.scrollY;
          const scrollDelta = currentScrollY - lastScrollY;
          const isAtBottom = window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - BOTTOM_THRESHOLD_PX;
          const isScrollingUp = scrollDelta < 0 && Math.abs(scrollDelta) > SCROLL_UP_THRESHOLD_PX;

          if (isAtBottom) {
            document.body.classList.remove('focus-mode');
          } else if (currentScrollY > lastScrollY && currentScrollY > SCROLL_DOWN_START_PX) {
            document.body.classList.add('focus-mode');
          } else if (isScrollingUp || currentScrollY < TOP_THRESHOLD_PX) {
            document.body.classList.remove('focus-mode');
          }

          lastScrollY = currentScrollY;
          ticking = false;
        };

        const handleScroll = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateFocusMode);
        };

        const cleanup = () => {
          window.removeEventListener('scroll', handleScroll);
          document.body.classList.remove('focus-mode');
        };

        window.addEventListener('scroll', handleScroll, { passive: true });
        window.addEventListener('pagehide', cleanup, { once: true });
      })();
    </script>
  </body>
</html>
