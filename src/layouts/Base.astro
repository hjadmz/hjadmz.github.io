---
import "../styles/global.css";
import MonolithLogo from "../components/MonolithLogo.astro";
import { CommandPalette } from "../components/CommandPalette";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = "hjadmz — design-engineering log. Research-backed systems. Shipped work.",
  ogImage = "/og-image-1200x630.png",
} = Astro.props;

const siteTitle = title === "Home" ? "hjadmz" : `${title} · hjadmz`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const path = Astro.url.pathname;
const pathSegments = path.split("/").filter(Boolean);

const nav = [
  { href: "/log", label: "log" },
  { href: "/work", label: "work" },
  { href: "/about", label: "about" },
  { href: "/contact", label: "contact" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <!--
      viewport-fit=cover enables safe-area-inset-* on iPhone notched
      devices. Without it, env(safe-area-inset-bottom) resolves to 0
      even inside webkit, and content gets hidden behind the home
      indicator. Required for the footer + scroll-to-top safe-area logic.
    -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#F9FAFB" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#020617" />
    <meta name="format-detection" content="telephone=no" />

    <!-- SEO -->
    <title>{siteTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="hjadmz" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={siteTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Author — alias-first per brand rule. The brand IS hjadmz. -->
    <meta name="author" content="hjadmz" />

    <!--
      JSON-LD — alias-first identity.
      Schema.org Person permits `name` to be any identifier; the brand
      spec mandates hjadmz as the only public-facing name. Google treats
      hjadmz as the entity for author markup and knowledge-graph
      resolution. No real name leaks into crawler-readable metadata.
    -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "hjadmz",
      "url": "https://hjadmz.com",
      "author": {
        "@type": "Person",
        "name": "hjadmz",
        "url": "https://hjadmz.com",
        "jobTitle": "Design Engineer",
        "knowsAbout": ["Human-Centered Computing", "Design Systems", "Accessibility", "TypeScript", "React"]
      },
      "description": "Design-engineering log. Research-backed systems. Shipped work."
    })} />

    <!-- Single SVG favicon with embedded prefers-color-scheme -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Feed discovery for RSS readers -->
    <link rel="alternate" type="application/rss+xml" title="hjadmz — log" href="/rss.xml" />

    <!-- Sitemap (generated by @astrojs/sitemap) -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!--
      Per-page head injection.
      Detail pages (log/[slug], work/[slug]) render BlogPosting JSON-LD here
      so crawlers can attach the entry to the alias-first Person entity
      declared above without the markup leaking into <body>. Any page that
      needs head-level metadata (canonical overrides, per-page structured
      data, preconnect hints) uses <Fragment slot="head-extras">.
    -->
    <slot name="head-extras" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <CommandPalette client:load />

    <!-- Focus Mode + Cmd+K listener + visible search button + platform-aware kbd -->
    <script>
      const threshold = 120;
      let ticking = false;
      const onScroll = () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            document.body.classList.toggle("focus-active", window.scrollY > threshold);
            ticking = false;
          });
          ticking = true;
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });

      const openPalette = () => window.dispatchEvent(new CustomEvent("open-palette"));

      window.addEventListener("keydown", (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key === "k") {
          e.preventDefault();
          openPalette();
        }
        if (e.key === "/" && !(e.target instanceof HTMLInputElement) && !(e.target instanceof HTMLTextAreaElement)) {
          e.preventDefault();
          openPalette();
        }
      });

      // Platform-aware modifier label: ⌘ on Apple, Ctrl on everything else.
      // `navigator.platform` is deprecated — prefer `userAgentData.platform`
      // where available (Chromium), fall back to userAgent. iOS/iPadOS report
      // "MacIntel" in modern Safari, so Mac token covers Apple silicon + iOS.
      const uaData = (navigator as unknown as { userAgentData?: { platform?: string } }).userAgentData;
      const platform = uaData?.platform ?? navigator.userAgent ?? "";
      const isApple = /Mac|iPhone|iPad|iPod/i.test(platform) ||
        (/Mac/i.test(platform) && "ontouchend" in document);
      document.querySelectorAll(".nav-search-mod").forEach((el) => {
        el.textContent = isApple ? "⌘" : "Ctrl ";
      });

      // Platform-aware tooltip on the search button
      const searchBtn = document.getElementById("nav-search");
      if (searchBtn) {
        searchBtn.setAttribute("title", isApple ? "Search  ⌘K" : "Search  Ctrl+K");
        searchBtn.addEventListener("click", openPalette);
      }
    </script>

    <div class="page-shell">
      <!-- Header -->
      <header class="focus-hide header-bar">
        <div class="reading-column header-inner">
          {/*
            Breadcrumb rendering policy (FCA audit, 2026-04-18):

            Depth-1 pages (/log, /work, /about, /contact, /spec, /tag):
              The active nav link on the right ALREADY says where you are.
              Rendering a breadcrumb segment here duplicates that signal —
              worse, on mid-narrow viewports it competes for space and
              clips (e.g. "about" → "ab..."). Under FCA, a redundant
              signal that also harms layout is a cut. So we render only
              the logo + wordmark (home link) and let the nav-link-active
              state do the wayfinding.

            Depth-2+ pages (/log/some-post, /tag/engineering, /work/proj):
              Breadcrumb IS load-bearing — it shows the parent section
              and gives the user a one-click back-to-parent affordance.
              Keep it. The @media(max-width:540px) rules in global.css
              further trim intermediate segments to prevent header wrap.
          */}
          <nav aria-label="Breadcrumb" class="breadcrumb-left">
            <a
              href="/"
              class:list={["breadcrumb-home", { "breadcrumb-active": pathSegments.length === 0 }]}
              aria-current={pathSegments.length === 0 ? "page" : undefined}
            >
              <MonolithLogo className="mark-icon" />
              <span>hjadmz</span>
            </a>
            {pathSegments.length >= 2 && pathSegments.map((segment, i) => {
              const isActive = i === pathSegments.length - 1;
              return (
                <>
                  <span class="breadcrumb-sep" aria-hidden="true">/</span>
                  <a
                    href={`/${pathSegments.slice(0, i + 1).join("/")}`}
                    class:list={["breadcrumb-segment", { "breadcrumb-active": isActive }]}
                    aria-current={isActive ? "page" : undefined}
                  >
                    {decodeURIComponent(segment)}
                  </a>
                </>
              );
            })}
          </nav>

          <nav aria-label="Primary" class="nav-right">
            {nav.map((item) => {
              const hrefSegments = item.href.split('/').filter(Boolean);
              const isActive = pathSegments.length >= hrefSegments.length
                && hrefSegments.every((seg, idx) => pathSegments[idx] === seg);
              return (
                <a
                  href={item.href}
                  class:list={["nav-link", { "nav-link-active": isActive }]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {item.label}
                </a>
              );
            })}

            <button
              id="nav-search"
              type="button"
              class="nav-search"
              aria-label="Search the site"
              title="Search  ⌘K"
            >
              {/*
                Stroke calibrated to render at ~1.45 CSS pixels so it
                visually matches the <Arrow> component's 1.5px stroke.
                The math: display 14 / viewBox 24 × stroke 2.5 = 1.46.
                Equal rendered stroke is what removes the "puffy search,
                thin arrows" mismatch — different unit ratios need
                different stroke values to look like one hand.
              */}
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="11" cy="11" r="7.5"></circle>
                <line x1="20.5" y1="20.5" x2="16.65" y2="16.65"></line>
              </svg>
              <kbd class="nav-search-kbd" aria-hidden="true"><span class="nav-search-mod">⌘</span>K</kbd>
            </button>
          </nav>
        </div>
      </header>

      <main id="main" class="reading-column main-content">
        <slot />
      </main>

      <!-- Footer -->
      <footer class="footer-bar">
        <div class="reading-column footer-inner">
          <div class="footer-centered-content">
            <!--
              No title attribute. No cursor: help. A native tooltip on the
              motto (a) leaked a short "a"-glyph artifact from the browser's
              chrome rendering next to the cursive capital, (b) attached a
              question-mark cursor that framed the mark as an explainer
              affordance rather than a signature. Soli Deo Gloria stands
              silent by design — Kintsugi rule. Anyone who wants the
              translation can look it up.
            -->
            <span class="footer-motto">Soli Deo Gloria</span>
            <div class="footer-meta-row">
              <span id="footer-clock" class="footer-clock"></span>
              <span class="footer-pipe" aria-hidden="true">|</span>
              <a href="/spec" class="footer-spec-link">SPEC</a>
              <span class="footer-pipe" aria-hidden="true">|</span>
              <a href="/rss.xml" class="footer-spec-link" aria-label="RSS feed">RSS</a>
            </div>
          </div>
        </div>
      </footer>

      <!-- Scroll-to-top: appears after threshold, keyboard accessible -->
      <button
        id="scroll-to-top"
        class="scroll-to-top"
        type="button"
        aria-label="Scroll to top"
        tabindex="-1"
      >
        {/* Stroke 2.5 on a 24-unit viewBox displayed at 14 renders at
            ~1.46 CSS pixels — same rendered weight as the site's other
            icons. Raw stroke-width values differ because the viewBoxes
            differ; rendered stroke is the thing that must match. */}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="12" y1="19" x2="12" y2="5"></line>
          <polyline points="5 12 12 5 19 12"></polyline>
        </svg>
      </button>
    </div>

    <script>
      // Live clock
      const clockEl = document.getElementById('footer-clock');
      if (clockEl) {
        const fmt = new Intl.DateTimeFormat('en-US', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
          timeZoneName: 'short',
        });
        const tick = () => { clockEl.textContent = fmt.format(new Date()); };
        tick();
        setInterval(tick, 1000);
      }

      // Scroll-to-top: visible past threshold, click smoothly scrolls up
      const scrollBtn = document.getElementById('scroll-to-top');
      if (scrollBtn) {
        const SHOW_THRESHOLD = 400;
        let scrollTicking = false;
        const updateVisibility = () => {
          const shouldShow = window.scrollY > SHOW_THRESHOLD;
          scrollBtn.classList.toggle('scroll-to-top-visible', shouldShow);
          scrollBtn.tabIndex = shouldShow ? 0 : -1;
          scrollTicking = false;
        };
        window.addEventListener('scroll', () => {
          if (!scrollTicking) {
            requestAnimationFrame(updateVisibility);
            scrollTicking = true;
          }
        }, { passive: true });
        scrollBtn.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });
      }
    </script>
  </body>
</html>
