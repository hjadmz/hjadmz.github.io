---
import BaseLayout from '../layouts/BaseLayout.astro';
import FcaCallout from '../components/FcaCallout.astro';
---
<BaseLayout
  title="hjadmz"
  description="hjadmz builds static-first interfaces with strong architecture, accessibility, and design token discipline."
>
  <h1 class="mb-8 intro-fade" style="--enter-delay: 30ms;">Design Engineer &amp;<br/>Systems Architect</h1>
  <p class="text-[var(--fg-muted)] max-w-[54ch] leading-relaxed mb-16 intro-fade" style="--enter-delay: 90ms;">
    Bridging human-centered computing with rigorous systems architecture.
    Operating under the architecture of my own <FcaCallout /> protocol—where technology is sculptural,
    and power is hidden inside silence.
  </p>

  <div class="grid gap-4">
    <a href="/log" class="group flex items-center gap-4 text-[var(--step-0)] text-[var(--fg)] no-underline w-fit intro-fade" style="--enter-delay: 150ms;">
      <span class="w-8 h-[1px] bg-[color:var(--fg)] opacity-20 group-hover:opacity-100 group-hover:w-16 transition-all duration-500 ease-out inline-block"></span>
      <span class="transition-transform duration-500 ease-out group-hover:translate-x-2">View log</span>
    </a>
    <a href="/work" class="group flex items-center gap-4 text-[var(--step-0)] text-[var(--fg)] no-underline w-fit intro-fade" style="--enter-delay: 200ms;">
      <span class="w-8 h-[1px] bg-[color:var(--fg)] opacity-20 group-hover:opacity-100 group-hover:w-16 transition-all duration-500 ease-out inline-block"></span>
      <span class="transition-transform duration-500 ease-out group-hover:translate-x-2">View work</span>
    </a>
    <a href="/about" class="group flex items-center gap-4 text-[var(--step-0)] text-[var(--fg)] no-underline w-fit intro-fade" style="--enter-delay: 250ms;">
      <span class="w-8 h-[1px] bg-[color:var(--fg)] opacity-20 group-hover:opacity-100 group-hover:w-16 transition-all duration-500 ease-out inline-block"></span>
      <span class="transition-transform duration-500 ease-out group-hover:translate-x-2">About me</span>
    </a>
  </div>
</BaseLayout>
