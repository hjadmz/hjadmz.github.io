---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts } from '../../data/posts';

export function getStaticPaths() {
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const related = posts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => ({
    candidate,
    score: candidate.tags.filter((tag) => post.tags.includes(tag)).length,
  }))
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    const aDate = Date.parse(a.candidate.date);
    const bDate = Date.parse(b.candidate.date);
    if (!Number.isNaN(aDate) && !Number.isNaN(bDate)) return bDate - aDate;
    return 0;
  })
  .slice(0, 2)
  .map(({ candidate }) => candidate);
---
<BaseLayout title={`${post.title} · hjadmz`}>
  <article class="prose">
    <header class="mb-8">
      <time class="text-xs font-mono text-[var(--fg-muted)]">{post.date}</time>
      <h1>{post.title}</h1>
    </header>

    <section class="card mb-8" aria-label="Key ideas">
      <h2>Key ideas</h2>
      <ul class="list-disc pl-5">
        {post.keyIdeas.map((idea) => <li>{idea}</li>)}
      </ul>
    </section>

    {post.sections.map((section) => (
      <section class="mb-8">
        <h2>{section.heading}</h2>
        {section.body.map((paragraph) => <p>{paragraph}</p>)}
      </section>
    ))}

    {related.length > 0 && (
      <section class="mb-8" aria-label="Related posts">
        <h2>Related posts</h2>
        <ul>
          {related.map((entry) => (
            <li><a href={`/log/${entry.slug}`}>{entry.title}</a></li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
