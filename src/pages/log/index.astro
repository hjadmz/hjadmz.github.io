---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entrySlug = (id: string) => id.replace(/\.mdx?$/, '');
const posts = (await getCollection('log')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---
<BaseLayout
  title="Log · hjadmz"
  description="Build journal, research notes, and architecture reflections from the hjadmz practice."
>
  <h1>Log</h1>
  <p>Build journal, research notes, and architecture reflections.</p>
  <div class="mt-8 grid gap-3">
    {posts.length > 0 ? posts.map((post) => (
      <article class="card">
        <time class="text-xs font-mono text-[var(--fg-muted)]">{post.data.date.toISOString().slice(0, 10)}</time>
        <h2><a href={`/log/${entrySlug(post.id)}`} class="link-subtle">{post.data.title}</a></h2>
        <p>{post.data.summary || 'No summary yet.'}</p>
        <ul class="flex flex-wrap gap-2 text-xs font-mono text-[var(--fg-muted)]">
          {post.data.tags.map((tag) => <li class="rounded-full border px-2 py-0.5">{tag}</li>)}
        </ul>
      </article>
    )) : (
      <p class="text-[var(--fg-muted)]">No log entries yet.</p>
    )}
  </div>
</BaseLayout>
