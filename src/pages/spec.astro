---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Spec · hjadmz">
  <h1>Technical Spec</h1>
  <div class="grid gap-4 font-mono text-sm">
    <div class="card">Color tokens: navy #020617, off-white #F9FAFB, white surfaces.</div>
    <div class="card">Type: Inter for UI/prose, JetBrains Mono for technical accents.</div>
    <div class="card">Spacing: 4/8 scale and fluid typography with clamp().</div>
    <div class="card">Motion: 120ms hover, 200ms component transitions, ease-out cubic-bezier(0.16, 1, 0.3, 1).</div>
  </div>
</BaseLayout>
