---
import Mark from './Mark.astro';
import ThemeToggle from './ThemeToggle.astro';
const path = Astro.url.pathname;
const nav = [
  { href: '/log', label: '/log' },
  { href: '/work', label: '/work' },
  { href: '/about', label: '/about' },
];
---
<header class="focus-element border-b border-[color:color-mix(in_srgb,var(--fg)_10%,transparent)] py-6">
  <div class="mx-auto flex w-full max-w-[72rem] items-start justify-between gap-6 px-4 sm:px-6 lg:px-8">
    <a href="/" class="logo-lockup inline-grid gap-1.5 no-underline">
      <span class="inline-flex items-center gap-2 text-[0.9rem] font-semibold tracking-[0.11em]">
        <Mark class="h-5 w-5" />
        <span>HJADMZ</span>
      </span>
      <span class="text-[0.72rem] uppercase tracking-[0.18em] text-[var(--fg-muted)]">Soli Deo Gloria</span>
    </a>
    <nav aria-label="Primary" class="flex flex-wrap items-center justify-end gap-3 text-sm">
      {nav.map((item) => {
        const linkClass = path === item.href
          ? 'link-subtle text-[var(--fg)]'
          : 'link-subtle text-[var(--fg-muted)]';

        return <a href={item.href} class={linkClass}>{item.label}</a>;
      })}
      <ThemeToggle />
    </nav>
  </div>
</header>
