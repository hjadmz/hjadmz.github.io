---
import Mark from './Mark.astro';
import ThemeToggle from './ThemeToggle.astro';
const path = Astro.url.pathname;
const nav = [
  { href: '/log', label: '/log' },
  { href: '/work', label: '/work' },
  { href: '/about', label: '/about' },
];
---
<header class="focus-element h-32 flex items-center">
  <div class="reading-column w-full flex items-center justify-between gap-8">
    <div class="min-w-0 flex-1">
      <a href="/" class="inline-flex items-center gap-2 no-underline text-[var(--step--1)] text-[var(--fg-muted)] hover:text-[var(--fg)] transition-colors">
        <Mark class="w-4 h-4 opacity-80" />
        <span>hjadmz</span>
      </a>
    </div>
    <nav aria-label="Primary" class="flex items-center gap-5 text-[var(--step--1)] shrink-0">
      {nav.map((item) => {
        const pathSegments = path.split('/').filter(Boolean);
        const hrefSegments = item.href.split('/').filter(Boolean);
        const isActive = pathSegments.length >= hrefSegments.length
          && hrefSegments.every((segment, index) => pathSegments[index] === segment);

        return (
          <a
            href={item.href}
            class={`link-subtle pb-0.5 ${isActive ? 'text-[var(--fg)]' : 'text-[var(--fg-muted)]'}`}
            aria-current={isActive ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
      <ThemeToggle />
    </nav>
  </div>
</header>
