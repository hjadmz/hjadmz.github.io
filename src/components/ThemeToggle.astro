<button
  id="theme-toggle"
  class="rounded-md border border-[color:color-mix(in_srgb,var(--fg)_16%,transparent)] min-h-11 min-w-11 px-3 py-2 text-xs font-mono text-[var(--fg-muted)]"
  type="button"
  aria-label="Toggle color theme"
>
  Theme
</button>

<script>
  const button = document.getElementById('theme-toggle');
  const root = document.documentElement;

  const setTheme = (next: 'light' | 'dark') => {
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
    button?.setAttribute('aria-pressed', String(next === 'dark'));
    button?.setAttribute('aria-label', next === 'dark' ? 'Switch to light theme' : 'Switch to dark theme');
  };

  const currentTheme: 'light' | 'dark' = root.dataset.theme === 'dark'
    ? 'dark'
    : root.dataset.theme === 'light'
      ? 'light'
      : window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  setTheme(currentTheme);

  button?.addEventListener('click', () => {
    setTheme(root.dataset.theme === 'dark' ? 'light' : 'dark');
  });
</script>
